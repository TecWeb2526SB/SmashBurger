# Configurazione Apache per la gestione delle rotte (routing)
# Questo file istruisce Apache su come gestire le richieste in arrivo.

# Gestione degli Errori HTTP personalizzati
# Istruisce Apache su quali file mostrare per determinati codici di errore.
ErrorDocument 403 /errors/403.php
ErrorDocument 404 /errors/404.php
ErrorDocument 500 /errors/500.php

# Abilitiamo il motore di riscrittura degli URL (URL rewriting)
RewriteEngine On

# Assicuriamoci che Apache segua i link simbolici (spesso richiesto per mod_rewrite)
Options +FollowSymLinks

# Regola: Se il file o la directory richiesti non esistono fisicamente sul server...
# RewriteCond %{REQUEST_FILENAME} !-f
# RewriteCond %{REQUEST_FILENAME} !-d

# ...allora reindirizza tutto al file index.php mantenendo i parametri della query string.
# Questo è essenziale per il funzionamento del routing in applicazioni PHP moderne.
# RewriteRule ^(.*)$ index.php?/$1 [L,QSA]

# Protezione extra: impediamo l'accesso a file sensibili (come .env o .git)
<FilesMatch "^\.">
    Order allow,deny
    Deny from all
</FilesMatch>